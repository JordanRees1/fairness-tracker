[Unit]
Description=Fairness Tracker
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
# Adjust User and paths to match your Pi.
User=user
WorkingDirectory=/home/pi/fairness
Environment=FAIRNESS_DB=/home/pi/fairness/fairness.db
# 1 worker keeps memory low and avoids SQLite write contention.
ExecStart=/home/pi/fairness/venv/bin/gunicorn --workers 1 --bind 0.0.0.0:8000 app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
